						"type": "AzureBlobFSReadSettings",
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			}
		],
		"parameters": {
			"blobContainerConfig": {
				"type": "string",
				"defaultValue": "000projectconfig"
			},
			"rawFolderpathConfig": {
				"type": "string",
				"defaultValue": "2402_iactransportationproject"
			}
		},
		"folder": {
			"name": "1- ToRaw"
		},
		"annotations": []
	}
