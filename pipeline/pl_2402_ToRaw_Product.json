					"dataset": {
						"referenceName": "ds_iac2402_RawFileCsv",
						"type": "DatasetReference",
						"parameters": {
							"blobContainer": {
								"value": "@activity('Fiter Config Product Flow To Load').output[0].FunctionalDomain",
								"type": "Expression"
							}
						}
					},
					"fieldList": [],
